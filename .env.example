# nfm-dashboard environment template
# Copy to .env and fill in real values. NEVER commit .env (only .env.example is tracked).
# In production these are injected by CDK (infra/lib/*-stack.ts); this file is for local dev.

# --- AWS ---
# Region where NfmDash-* stacks are deployed
AWS_REGION=ap-northeast-2

# --- Runtime ---
# development | production
NODE_ENV=development

# --- Collector (Lambda) ---
# Comma-separated Network Flow Monitor names to collect (CDK context: nfmMonitors)
MONITORS=
# Collect extended metric categories every N cycles (default: 3)
EXTENDED_CATEGORY_EVERY=3
# Run the DNS pass every N cycles (~15 min at rate(5 minutes), default: 3)
DNS_COLLECT_EVERY=3
# Comma-separated core DNS scope groups (optional)
DNS_CORE_GROUPS=
# SSM parameter path for the resolver DNS group
DNS_RESOLVER_GROUP=/nfm-dashboard/resolver-dns
# Parallel monitor queries per cycle (default: 5)
CONCURRENCY=5
# DynamoDB table names (created by NfmDash-Data stack)
TABLE_META=
TABLE_FLOWS=

# --- App (Next.js dashboard) ---
# Public URL of the dashboard (CloudFront domain in production)
APP_URL=http://localhost:3000
# Set to 1 to bypass Cognito auth for local dev: AUTH_DISABLED=1 npm -w app run dev
AUTH_DISABLED=1
# On-demand collector Lambda function name (refresh button)
COLLECTOR_FUNCTION=

# --- Auth (Cognito) --- values from NfmDash-App stack outputs; not needed when AUTH_DISABLED=1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=

# --- Secrets (placeholders only - real values live in AWS Secrets Manager) ---
# CloudFront -> ALB origin verification header secret
ORIGIN_VERIFY_SECRET=
# Cognito admin password: stored in Secrets Manager (see scripts/save-cognito-secret.sh).
# Do NOT put the real password here.
# COGNITO_ADMIN_PASSWORD=<stored-in-secrets-manager>
