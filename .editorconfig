# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
# Trailing spaces are meaningful in Markdown (hard line breaks)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
